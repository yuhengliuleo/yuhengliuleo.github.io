    <item>
      <title>11月希望组合收益报告</title>
      <link>https://yuhengliuleo.github.io/%E5%88%86%E7%B1%BB/%E6%94%B6%E7%9B%8A%E6%8A%A5%E5%91%8A/asset-structure-11-27/</link>
