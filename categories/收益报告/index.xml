      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;&lt;strong&gt;大中华区&lt;/strong&gt;&lt;/td&gt;
          &lt;td style=&#34;text-align: right&#34;&gt;2.31%&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;债券&lt;/td&gt;
          &lt;td style=&#34;text-align: right&#34;&gt;12.51%&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;加密货币&lt;/td&gt;
          &lt;td style=&#34;text-align: right&#34;&gt;13.41%&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;原油&lt;/td&gt;
