          &lt;td&gt;美国股票&lt;/td&gt;
          &lt;td style=&#34;text-align: right&#34;&gt;23.26%&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;欧洲股票&lt;/td&gt;
          &lt;td style=&#34;text-align: right&#34;&gt;5.21%&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
