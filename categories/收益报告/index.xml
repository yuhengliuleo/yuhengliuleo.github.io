          &lt;th style=&#34;text-align: center&#34;&gt;占总资金比例&lt;/th&gt;
      &lt;/tr&gt;
  &lt;/thead&gt;
  &lt;tbody&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;BTC&lt;/td&gt;
